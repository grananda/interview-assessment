{
  "name": "@repo/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Contratos compartidos (DTOs, modelos y tipos) entre frontend Angular y backend NestJS",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
